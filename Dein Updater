import requests
import zipfile
import io
import os
import subprocess
import json

VERSION_URL = "https://raw.githubusercontent.com/dessperado30-gif/ErsanMailClient/main/version.json"
LOCAL_VERSION = "1.0.100"

def check_for_updates():
    response = requests.get(VERSION_URL)
    data = response.json()

    online_version = data["version"]

    if online_version != LOCAL_VERSION:
        print(f"Neue Version verfügbar: {online_version}")

        if data["base_version"] == LOCAL_VERSION:
            apply_delta_update(data["delta_url"])
        else:
            download_full_update(data["download_url"])
    else:
        print("Du hast die neueste Version.")

def apply_delta_update(url):
    print("Lade Delta‑Update...")
    r = requests.get(url)
    z = zipfile.ZipFile(io.BytesIO(r.content))
    z.extractall(".")
    print("Delta‑Update angewendet.")
    restart_app()

def download_full_update(url):
    print("Lade vollständiges Update...")
    exe_path = "update_installer.exe"
    r = requests.get(url)
    with open(exe_path, "wb") as f:
        f.write(r.content)
    subprocess.Popen([exe_path])
    os._exit(0)

def restart_app():
    print("Starte App neu...")
    os.startfile("ErsanMailClient.exe")
    os._exit(0)
